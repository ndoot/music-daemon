# .env template for music-daemon

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_ALLOWED_USER_ID=your_id_here

# Spotify Configuration
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# slskd Configuration
SLSKD_USERNAME=your_slskd_username
SLSKD_PASSWORD=your_slskd_password
SLSKD_API_KEY=your_slskd_api_key
SLSKD_URL=http://localhost:5030

# Path Configuration
DOWNLOAD_DIR=./downloads
ICLOUD_MUSIC_DIR=/Users/YourUsername/Library/Mobile Documents/com~apple~CloudDocs/Music
